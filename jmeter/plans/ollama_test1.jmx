        </hashTree>

        <!-- ==================== 性能监控采样器 ==================== -->
        <JSR223Sampler guiclass="TestBeanGUI" testclass="JSR223Sampler" testname="性能监控采样器">
          <stringProp name="scriptLanguage">groovy</stringProp>
          <stringProp name="script">// 记录当前请求的性能数据到Props（用于全局统计）
def totalTokens = vars.get(&quot;total_tokens&quot;)
def responseTime = prev.getTime()

if (totalTokens != null &amp;&amp; totalTokens.isInteger() &amp;&amp; totalTokens.toInteger() &gt; 0) {
    def currentTotalTokens = props.get(&quot;total_tokens_sum&quot;)
    def currentRequestCount = props.get(&quot;total_requests_count&quot;)

    props.put(&quot;total_tokens_sum&quot;, (currentTotalTokens ? currentTotalTokens.toInteger() : 0) + totalTokens.toInteger())
    props.put(&quot;total_requests_count&quot;, (currentRequestCount ? currentRequestCount.toInteger() : 0) + 1)

    // 记录响应时间
    def totalResponseTime = props.get(&quot;total_response_time&quot;)
    props.put(&quot;total_response_time&quot;, (totalResponseTime ? totalResponseTime.toLong() : 0) + responseTime)
}

// 计算当前TPS（每10秒更新一次）
def currentTime = System.currentTimeMillis() / 1000
def lastCalcTime = props.get(&quot;last_tps_calc_time&quot;)

if (lastCalcTime == null || currentTime - lastCalcTime.toLong() &gt; 10) {
    def totalRequests = props.get(&quot;total_requests_count&quot;)?.toInteger() ?: 0
    props.put(&quot;last_tps_calc_time&quot;, currentTime.toString())
    props.put(&quot;last_tps_requests&quot;, totalRequests.toString())
}</stringProp>
        </JSR223Sampler>
