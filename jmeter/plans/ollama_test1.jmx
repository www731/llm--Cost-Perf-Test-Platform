              <code>true</code>
              <message>true</message>
              <threadName>true</threadName>
              <dataType>true</dataType>
              <encoding>false</encoding>
              <assertions>true</assertions>
              <subresults>true</subresults>
              <responseData>false</responseData>
              <samplerData>false</samplerData>
              <xml>false</xml>
              <fieldNames>true</fieldNames>
              <responseHeaders>false</responseHeaders>
              <requestHeaders>false</requestHeaders>
              <responseDataOnError>true</responseDataOnError>
              <saveAssertionResultsFailureMessage>true</saveAssertionResultsFailureMessage>
              <assertionsResultsToSave>0</assertionsResultsToSave>
              <bytes>true</bytes>
              <sentBytes>true</sentBytes>
              <url>true</url>
              <threadCounts>true</threadCounts>
              <idleTime>true</idleTime>
              <connectTime>true</connectTime>
            </value>
          </objProp>
        </ResultCollector>
        <hashTree/>

        <!-- 活跃线程数监控 -->
        <ResultCollector guiclass="MonitorHealthVisualizer" testclass="ResultCollector" testname="活跃线程监控">
          <boolProp name="ResultCollector.error_logging">false</boolProp>
        </ResultCollector>
        <hashTree/>

      </hashTree>

      <!-- ==================== 全局后处理器 ==================== -->

      <!-- JSR223监听器：测试结束时输出汇总信息 -->
      <ResultCollector guiclass="BeanShellListenerGui" testclass="ResultCollector" testname="JSR223监听器 - 测试汇总">
        <stringProp name="filename"></stringProp>
        <collectionProp name="Arguments.arguments"/>
        <stringProp name="script">import groovy.json.JsonBuilder
import java.text.SimpleDateFormat

// 测试结束时的汇总处理
def endTime = System.currentTimeMillis()
def totalRequests = props.get("total_requests_count")?.toInteger() ?: 0
def totalTokens = props.get("total_tokens_sum")?.toInteger() ?: 0
def totalResponseTime = props.get("total_response_time")?.toLong() ?: 0

log.info("="*50)
log.info("Ollama测试汇总")
log.info("="*50)
log.info("总请求数: " + totalRequests)
log.info("总Token数: " + totalTokens)
log.info("平均每请求Token: " + (totalRequests > 0 ? (totalTokens / totalRequests) : 0))
log.info("平均响应时间: " + (totalRequests > 0 ? (totalResponseTime / totalRequests) : 0) + " ms")

// 计算TPS
def startTime = Long.parseLong(vars.get("TEST_START_TIME") ?: "0")
if (startTime > 0) {
    def durationSec = (endTime - startTime) / 1000
    def tps = totalRequests / durationSec
    log.info("总耗时: " + durationSec + " 秒")
    log.info("平均TPS: " + String.format("%.2f", tps))
}

// 生成简单JSON报告
def summary = [
    test_time: new SimpleDateFormat("yyyy-MM-dd HH:mm:ss").format(new Date()),
    total_requests: totalRequests,
    total_tokens: totalTokens,
    avg_tokens_per_request: totalRequests > 0 ? (totalTokens / totalRequests) : 0,
    avg_response_time_ms: totalRequests > 0 ? (totalResponseTime / totalRequests) : 0,
    model: vars.get("model"),
    concurrent_users: vars.get("users")
]

def jsonFile = new File("results/summary/ollama-summary-" + System.currentTimeMillis() + ".json")
jsonFile.write(new JsonBuilder(summary).toPrettyString())

log.info("汇总已保存: " + jsonFile.getAbsolutePath())
log.info("="*50)</stringProp>
        <stringProp name="scriptLanguage">groovy</stringProp>
      </ResultCollector>
      <hashTree/>

      <!-- 记录测试开始时间 -->
      <JSR223PreProcessor guiclass="TestBeanGUI" testclass="JSR223PreProcessor" testname="记录测试开始时间">
        <stringProp name="scriptLanguage">groovy</stringProp>
        <stringProp name="script">vars.put("TEST_START_TIME", System.currentTimeMillis().toString())</stringProp>
      </JSR223PreProcessor>
      <hashTree/>

    </hashTree>

    <!-- ==================== 测试计划默认配置 ==================== -->
    <WorkBench guiclass="WorkBenchGui" testclass="WorkBench" testname="工作台"/>
    <hashTree/>

  </hashTree>
</jmeterTestPlan>