      <!-- 计数器（用于生成唯一ID） -->
      <CounterConfig guiclass="CounterConfigGui" testclass="CounterConfig" testname="请求计数器">
        <boolProp name="CounterConfig.per_user">false</boolProp>
        <boolProp name="CounterConfig.reset_on_thread_group_iteration">false</boolProp>
        <stringProp name="CounterConfig.start">1</stringProp>
        <stringProp name="CounterConfig.end">1000000</stringProp>
        <stringProp name="CounterConfig.incr">1</stringProp>
        <stringProp name="CounterConfig.format">00000</stringProp>
        <stringProp name="CounterConfig.var_name">request_id</stringProp>
      </CounterConfig>
