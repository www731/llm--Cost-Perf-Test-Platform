        <!-- ==================== 事务控制器 ==================== -->
        <TransactionController guiclass="TransactionControllerGui" testclass="TransactionController" testname="Ollama请求事务">
          <boolProp name="TransactionController.includeTimers">false</boolProp>
          <boolProp name="TransactionController.parent">false</boolProp>
        </TransactionController>
        <hashTree>

          <!-- ==================== HTTP请求：非流式生成 ==================== -->
          <HTTPSamplerProxy guiclass="HttpTestSampleGui" testclass="HTTPSamplerProxy" testname="Ollama Generate (非流式)">
            <boolProp name="HTTPSampler.postBodyRaw">true</boolProp>
            <elementProp name="HTTPSampler.Arguments" elementType="Arguments">
              <collectionProp name="Arguments.arguments">
                <elementProp name="request_body" elementType="HTTPArgument">
                  <boolProp name="HTTPArgument.always_encode">false</boolProp>
                  <stringProp name="Argument.value">{
  "model": "${model}",
  "prompt": "${prompt}",
  "stream": ${stream},
  "options": {
    "temperature": ${temperature},
    "num_predict": ${max_tokens},
    "top_p": ${top_p},
    "stop": ["\n\n", "User:", "Human:"]
  }
}</stringProp>
                  <stringProp name="Argument.metadata">=</stringProp>
                </elementProp>
              </collectionProp>
            </elementProp>
            <stringProp name="HTTPSampler.domain">localhost</stringProp>
            <stringProp name="HTTPSampler.port">11434</stringProp>
            <stringProp name="HTTPSampler.protocol">http</stringProp>
            <stringProp name="HTTPSampler.contentEncoding">UTF-8</stringProp>
            <stringProp name="HTTPSampler.path">/api/generate</stringProp>
            <stringProp name="HTTPSampler.method">POST</stringProp>
            <boolProp name="HTTPSampler.follow_redirects">false</boolProp>
            <boolProp name="HTTPSampler.auto_redirects">false</boolProp>
            <boolProp name="HTTPSampler.use_keepalive">true</boolProp>
            <boolProp name="HTTPSampler.DO_MULTIPART_POST">false</boolProp>
            <boolProp name="HTTPSampler.BROWSER_COMPATIBLE_MULTIPART">false</boolProp>
          </HTTPSamplerProxy>
          <hashTree>

            <!-- JSON提取器：提取响应内容 -->
            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="JSON提取器 - 响应内容">
              <stringProp name="JSONPostProcessor.referenceNames">ollama_response</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.response</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">0</stringProp>
            </JSONPostProcessor>
            <hashTree/>

            <!-- JSON提取器：提取Token信息（Ollama格式） -->
            <JSONPostProcessor guiclass="JSONPostProcessorGui" testclass="JSONPostProcessor" testname="JSON提取器 - Token信息">
              <stringProp name="JSONPostProcessor.referenceNames">prompt_eval_count,eval_count,total_duration,prompt_eval_duration,eval_duration</stringProp>
              <stringProp name="JSONPostProcessor.jsonPathExprs">$.prompt_eval_count,$.eval_count,$.total_duration,$.prompt_eval_duration,$.eval_duration</stringProp>
              <stringProp name="JSONPostProcessor.match_numbers">0</stringProp>
            </JSONPostProcessor>
            <hashTree/>

            <!-- JSR223后处理器：处理Ollama响应 -->
            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223后处理器 - Ollama响应处理">
              <stringProp name="cacheKey"></stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">import groovy.json.JsonSlurper

// 获取响应数据
def responseData = prev.getResponseDataAsString()
def responseCode = prev.getResponseCode()

log.info("Ollama响应状态码: " + responseCode)

if (responseCode == "200") {
    try {
        // 解析JSON
        def jsonResponse = new JsonSlurper().parseText(responseData)

        // 提取Token信息
        def promptTokens = jsonResponse.prompt_eval_count ?: 0
        def completionTokens = jsonResponse.eval_count ?: 0
        def totalTokens = promptTokens + completionTokens

        // 提取耗时信息（纳秒转毫秒）
        def totalDurationMs = jsonResponse.total_duration ? jsonResponse.total_duration / 1000000 : 0
        def promptEvalDurationMs = jsonResponse.prompt_eval_duration ? jsonResponse.prompt_eval_duration / 1000000 : 0
        def evalDurationMs = jsonResponse.eval_duration ? jsonResponse.eval_duration / 1000000 : 0

        // 存储变量
        vars.put("prompt_tokens", promptTokens.toString())
        vars.put("completion_tokens", completionTokens.toString())
        vars.put("total_tokens", totalTokens.toString())
        vars.put("total_duration_ms", totalDurationMs.toString())
        vars.put("prompt_eval_duration_ms", promptEvalDurationMs.toString())
        vars.put("eval_duration_ms", evalDurationMs.toString())

        // 计算Tokens Per Second
        if (evalDurationMs > 0) {
            def tokensPerSec = completionTokens / (evalDurationMs / 1000)
            vars.put("tokens_per_sec", String.format("%.2f", tokensPerSec))
        }

        // 提取响应内容（用于日志）
        def responseText = jsonResponse.response ?: ""
        if (responseText.length() > 200) {
            responseText = responseText.substring(0, 200) + "..."
        }
        vars.put("response_preview", responseText)

        log.info(String.format("Ollama Token - prompt:%d, completion:%d, total:%d, tokens/s:%s",
            promptTokens, completionTokens, totalTokens, vars.get("tokens_per_sec")))

    } catch (Exception e) {
        log.error("解析Ollama响应失败: " + e.toString())
        log.error("响应内容: " + responseData.substring(0, Math.min(500, responseData.length())))
        vars.put("total_tokens", "0")
    }
} else {
    log.warn("Ollama请求失败，状态码: " + responseCode)
    vars.put("total_tokens", "0")
}</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
            <hashTree/>

            <!-- 修改断言：使用更宽松的成功判断 -->
            <ResponseAssertion guiclass="AssertionGui" testclass="ResponseAssertion" testname="响应断言 - 状态码200">
