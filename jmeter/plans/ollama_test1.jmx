<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0">
  <hashTree>
    <!-- 测试计划配置 -->
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Ollama本地模型性能测试计划">
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments">
        <collectionProp name="Arguments.arguments">
          <elementProp name="OLLAMA_BASE_URL" elementType="Argument">
            <stringProp name="Argument.name">OLLAMA_BASE_URL</stringProp>
            <stringProp name="Argument.value">http://localhost:11434</stringProp>
            <stringProp name="Argument.desc">Ollama服务基础URL</stringProp>
          </elementProp>
          <elementProp name="MODEL_NAME" elementType="Argument">
            <stringProp name="Argument.name">MODEL_NAME</stringProp>
            <stringProp name="Argument.value">deepseek-r1:1.5b</stringProp>
            <stringProp name="Argument.desc">模型名称</stringProp>
          </elementProp>
          <elementProp name="CONCURRENT_USERS" elementType="Argument">
            <stringProp name="Argument.name">CONCURRENT_USERS</stringProp>
            <stringProp name="Argument.value">20</stringProp>
            <stringProp name="Argument.desc">并发用户数</stringProp>
          </elementProp>
          <elementProp name="TEST_DURATION" elementType="Argument">
            <stringProp name="Argument.name">TEST_DURATION</stringProp>
            <stringProp name="Argument.value">300</stringProp>
            <stringProp name="Argument.desc">测试持续时间</stringProp>
          </elementProp>
          <elementProp name="RAMP_UP" elementType="Argument">
            <stringProp name="Argument.name">RAMP_UP</stringProp>
            <stringProp name="Argument.value">30</stringProp>
            <stringProp name="Argument.desc">预热时间</stringProp>
          </elementProp>
          <elementProp name="TEMPERATURE" elementType="Argument">
            <stringProp name="Argument.name">TEMPERATURE</stringProp>
            <stringProp name="Argument.value">0.7</stringProp>
            <stringProp name="Argument.desc">温度参数</stringProp>
          </elementProp>
          <elementProp name="MAX_TOKENS" elementType="Argument">
            <stringProp name="Argument.name">MAX_TOKENS</stringProp>
            <stringProp name="Argument.value">1024</stringProp>
            <stringProp name="Argument.desc">最大token数</stringProp>
          </elementProp>
          <elementProp name="TOP_P" elementType="Argument">
            <stringProp name="Argument.name">TOP_P</stringProp>
            <stringProp name="Argument.value">0.9</stringProp>
            <stringProp name="Argument.desc">Top-p参数</stringProp>
          </elementProp>
          <elementProp name="STREAM" elementType="Argument">
            <stringProp name="Argument.name">STREAM</stringProp>
            <stringProp name="Argument.value">false</stringProp>
            <stringProp name="Argument.desc">是否流式输出</stringProp>
          </elementProp>
        </collectionProp>
      </elementProp>
    </TestPlan>
    <hashTree>

      <!-- ==================== 全局配置 ==================== -->

      <!-- 用户定义变量（可被命令行覆盖） -->
      <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="用户定义变量">
        <collectionProp name="Arguments.arguments">
          <elementProp name="base_url" elementType="Argument">
            <stringProp name="Argument.name">base_url</stringProp>
            <stringProp name="Argument.value">${__P(base_url,http://localhost:11434)}</stringProp>
            <stringProp name="Argument.desc">Ollama服务地址</stringProp>
          </elementProp>
          <elementProp name="model" elementType="Argument">
            <stringProp name="Argument.name">model</stringProp>
            <stringProp name="Argument.value">${__P(model,deepseek-r1:1.5b)}</stringProp>
            <stringProp name="Argument.desc">模型名称</stringProp>
          </elementProp>
          <elementProp name="users" elementType="Argument">
            <stringProp name="Argument.name">users</stringProp>
            <stringProp name="Argument.value">${__P(users,20)}</stringProp>
            <stringProp name="Argument.desc">并发用户数</stringProp>
          </elementProp>
          <elementProp name="duration" elementType="Argument">
            <stringProp name="Argument.name">duration</stringProp>
            <stringProp name="Argument.value">${__P(duration,300)}</stringProp>
            <stringProp name="Argument.desc">测试时长(秒)</stringProp>
          </elementProp>
          <elementProp name="rampup" elementType="Argument">
            <stringProp name="Argument.name">rampup</stringProp>
            <stringProp name="Argument.value">${__P(rampup,30)}</stringProp>
            <stringProp name="Argument.desc">爬升时间(秒)</stringProp>
          </elementProp>
          <elementProp name="temperature" elementType="Argument">
            <stringProp name="Argument.name">temperature</stringProp>
            <stringProp name="Argument.value">${__P(temperature,0.7)}</stringProp>
            <stringProp name="Argument.desc">温度参数</stringProp>
          </elementProp>
          <elementProp name="max_tokens" elementType="Argument">
            <stringProp name="Argument.name">max_tokens</stringProp>
            <stringProp name="Argument.value">${__P(max_tokens,1024)}</stringProp>
            <stringProp name="Argument.desc">最大输出token</stringProp>
          </elementProp>
          <elementProp name="stream" elementType="Argument">
            <stringProp name="Argument.name">stream</stringProp>
            <stringProp name="Argument.value">${__P(stream,false)}</stringProp>
            <stringProp name="Argument.desc">是否流式输出</stringProp>
          </elementProp>
          <elementProp name="top_p" elementType="Argument">
            <stringProp name="Argument.name">top_p</stringProp>
            <stringProp name="Argument.value">${__P(top_p,0.9)}</stringProp>
            <stringProp name="Argument.desc">Top-p参数</stringProp>
          </elementProp>
          <elementProp name="budget" elementType="Argument">
            <stringProp name="Argument.name">budget</stringProp>
            <stringProp name="Argument.value">${__P(budget,1.0)}</stringProp>
            <stringProp name="Argument.desc">预算限制(美元)</stringProp>
          </elementProp>
        </collectionProp>
      </Arguments>
